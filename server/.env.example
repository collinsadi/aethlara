# Server
APP_ENV=development
PORT=8080
APP_URL=http://localhost:8080
APP_NAME=Aethlara

# Database
DATABASE_URL=postgres://user:password@localhost:5432/aethlara_db?sslmode=disable

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-replace-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-replace-this
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Rate Limiting (per IP, all /api/v1 routes — raise for local SPA dev)
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST=60

# Security
BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_PROXIES=

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=noreply@aethlara.com
EMAIL_FROM_NAME=Aethlara
# Set to true in local dev to skip Resend and print the OTP in server logs (never enable in production)
EMAIL_DEV_LOG_ONLY=false

# OpenRouter AI
# NOTE: There is NO platform-level OpenRouter key. Every AI call uses the
# authenticated user's own encrypted key, which they add via Settings → API Key.
# If a user has no valid key, all AI-dependent endpoints return 403
# API_KEY_REQUIRED.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Resume processing
RESUME_MAX_FILE_SIZE_MB=5
RESUME_PRESIGNED_URL_EXPIRY_MINUTES=15
RESUME_MAX_ACTIVE_PER_USER=10

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id-replace-this
R2_ACCESS_KEY_ID=your-r2-access-key-id-replace-this
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-replace-this
R2_BUCKET_NAME=your-r2-bucket-name-replace-this
R2_PUBLIC_ENDPOINT=https://your-r2-public-endpoint-replace-this

# Scraper
SCRAPER_REQUEST_TIMEOUT_SECONDS=15
SCRAPER_MAX_HTML_BYTES=2097152
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; Aethlara/1.0)
ALLOWED_SCRAPE_SCHEMES=https

# Job processing
JOB_MAX_TEXT_INPUT_BYTES=51200
# Hard ceiling for the job AI pipeline (extract + align). The AI context is
# decoupled from the inbound HTTP request so this deadline applies even when
# the client disconnects.
JOB_AI_TIMEOUT_SECONDS=120
JOB_PDF_MAX_RETRIES=3

# PDF
PDF_STORAGE_PREFIX=jobs/resumes/
PDF_TEMPLATE=minimal

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100


# API key encryption
API_KEY_ENCRYPTION_SECRET=your-api-key-encryption-secret-replace-this
API_KEY_PREVIEW_LENGTH=18

# Chrome extension auth
EXTENSION_TOKEN_EXPIRY_SECS=60
EXTENSION_TOKEN_RATE_PER_HOUR=5
DASHBOARD_URL=http://localhost:5173