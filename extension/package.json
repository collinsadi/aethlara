{
  "name": "aethlara-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && EXT_ENTRY=popup vite build && EXT_ENTRY=background vite build && EXT_ENTRY=content vite build",
    "dev": "npm run build && EXT_ENTRY=popup vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
